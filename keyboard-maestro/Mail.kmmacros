						<key>Path</key>
						<string></string>
						<key>Text</key>
						<string>tell application "Mail"	set msgs to selection	if msgs is {} then return	repeat with msg in msgs		set accName to name of account of mailbox of msg		set msgSource to source of msg		set tmpFile to "/tmp/mail_archive_" &amp; ((random number from 10000 to 99999) as string) &amp; ".eml"		set fileRef to open for access POSIX file tmpFile with write permission		set eof of fileRef to 0		write msgSource to fileRef		close access fileRef		do shell script "curl -s -X POST https://mail.srvc.es/archive -F 'account=" &amp; accName &amp; "' -F 'eml=@" &amp; tmpFile &amp; "' &gt; /dev/null 2&gt;&amp;1 &amp;&amp; rm " &amp; quoted form of tmpFile &amp; " &amp;"	end repeatend tell</string>
