						<key>Path</key>
						<string></string>
						<key>Text</key>
						<string>tell application "Mail"
    set msgs to selection
    if msgs is {} then return
    
    repeat with msg in msgs
        set msgAccount to account of mailbox of msg
        set targetMailbox to mailbox "Per Dopo" of msgAccount
        move msg to targetMailbox
    end repeat
end tell</string>
